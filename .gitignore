.DS_Store
node_modules
videos

# Generated fixture media (conference clips, not ours to redistribute).
# Regenerate with: node test/tools/make-fixtures.mjs
test/fixtures/media/

# Test-data drop folder: transcripts/videos are large + may not be
# redistributable. Keep local; only the README is tracked.
test/fixtures/src/*
!test/fixtures/src/README.md

# Generated by `npm run sources` from test/fixtures/src/. The two small test
# clips stay committed (the automated tests load them).
test/fixtures/transcripts/*.json
!test/fixtures/transcripts/clip-a.json
!test/fixtures/transcripts/clip-b.json
test/fixtures/sources.json

# Playwright output
test-results/
playwright-report/

